{
  "name": "@liquidglass/svelte",
  "version": "0.1.0",
  "description": "Svelte action for @liquidglass/core",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@liquidglass/core": "workspace:^"
  },
  "peerDependencies": {
    "svelte": "^4.0.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "svelte": {
      "optional": true
    }
  },
  "keywords": [
    "liquid-glass",
    "svelte",
    "glassmorphism"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Surdeddd/liquidglassjs.git",
    "directory": "packages/svelte"
  },
  "publishConfig": {
    "access": "public"
  }
}
