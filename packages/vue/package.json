{
  "name": "@surdeddd/liquidglass-vue",
  "version": "0.2.0",
  "description": "Vue 3 component and directive for @surdeddd/liquidglass-core",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@surdeddd/liquidglass-core": "workspace:^"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "keywords": [
    "liquid-glass",
    "vue",
    "glassmorphism"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Surdeddd/liquidglassjs.git",
    "directory": "packages/vue"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "vue": "^3.5.39"
  }
}
