{
  "name": "liquidglassjs",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" run build",
    "build:docs": "pnpm build && pnpm --filter docs run build && pnpm docs:api",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint .",
    "test": "pnpm -r --filter \"./packages/*\" --filter react18-smoke run test",
    "e2e": "playwright test",
    "ssr": "node scripts/ssr-smoke.mjs",
    "size": "size-limit",
    "changeset": "changeset",
    "release": "pnpm build && changeset publish",
    "docs:api": "typedoc"
  },
  "size-limit": [
    {
      "path": "packages/core/dist/index.js",
      "limit": "24 kB"
    }
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@types/node": "^26.1.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "size-limit": "^12.1.0",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.20",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
